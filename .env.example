# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/march_madness?schema=public"

# Auth.js / admin auth
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_TRUST_HOST="true"
ADMIN_USERNAME="admin"

# bcrypt hash for admin password.
# Next.js expands $ in .env files, so literal dollar signs must be escaped as \$.
# Example: ADMIN_PASSWORD_HASH="\$2b\$10\$..."
ADMIN_PASSWORD_HASH="\$2b\$10\$replace-with-bcrypt-hash"

# NCAA sync overrides (all optional)
NCAA_SCORES_URL=""
NCAA_SCORES_BASE_URL=""
NCAA_SCORES_DATE=""
NCAA_SCORES_TIMEZONE="America/New_York"
NCAA_SCORES_FETCH_TIMEOUT_MS="15000"
