generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BracketType {
  MAIN
  SECOND_CHANCE_S16
  CHAMPIONSHIP
}

model Entry {
  id               String   @id @default(cuid())
  name             String
  participantName  String
  bracketType      BracketType @default(MAIN)
  picksJson        Json
  tiebreakerJson   Json?
  totalScore       Int      @default(0)
  correctPicks     Int      @default(0)
  maxPossibleScore Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Game {
  id           String   @id
  round        String
  region       String?
  slotLabel    String
  homeTeam     String?
  homeTeamKey  String?
  homeScore    Int?
  awayTeam     String?
  awayTeamKey  String?
  awayScore    Int?
  winnerTeam   String?
  winnerTeamKey String?
  status       String   @default("pending")
  scheduledDate DateTime?
  syncSource   String?
  lastSyncedAt DateTime?
}

model SyncRun {
  id         String   @id @default(cuid())
  source     String
  startedAt  DateTime
  finishedAt DateTime?
  status     String
  summaryJson Json
}

model TeamSlotAssignment {
  teamKey   String   @id
  teamName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
