generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Entry {
  id               String   @id @default(cuid())
  name             String
  participantName  String
  picksJson        Json
  totalScore       Int      @default(0)
  maxPossibleScore Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Game {
  id           String   @id
  round        String
  region       String?
  slotLabel    String
  homeTeam     String?
  awayTeam     String?
  winnerTeam   String?
  status       String   @default("pending")
  scheduledDate DateTime?
  syncSource   String?
  lastSyncedAt DateTime?
}

model SyncRun {
  id         String   @id @default(cuid())
  source     String
  startedAt  DateTime
  finishedAt DateTime?
  status     String
  summaryJson Json
}
